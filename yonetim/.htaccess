DirectoryIndex giris.php

<IfModule mod_rewrite.c>
RewriteEngine On

RewriteRule ^assets/ - [L]

RewriteCond %{QUERY_STRING} (^|.*&)(slug)=([^&]*)(.*)$ [NC]
RewriteRule ^ %{REQUEST_URI}?%1ad=%3%4 [R=301,L,NE]
RewriteCond %{QUERY_STRING} (^|.*&)(id)=([^&]*)(.*)$ [NC]
RewriteRule ^ %{REQUEST_URI}?%1kimlik=%3%4 [R=301,L,NE]
RewriteCond %{QUERY_STRING} (^|.*&)(new)=([^&]*)(.*)$ [NC]
