RewriteRule ^ %{REQUEST_URI}?%1durum=%3%4 [R=301,L,NE]
RewriteCond %{QUERY_STRING} (^|.*&)(days)=([^&]*)(.*)$ [NC]
RewriteRule ^ %{REQUEST_URI}?%1gun=%3%4 [R=301,L,NE]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^index\.php$ giris [R=301,L,QSA,NE]
RewriteRule ^dashboard\.php$ ozet [R=301,L,QSA,NE]
